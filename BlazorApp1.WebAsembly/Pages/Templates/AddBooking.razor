@using BlazorApp1.Entities.Dto

<h3>Add Booking</h3>
<EditForm Model="@FormBooking" OnValidSubmit="@SubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="form-group">
        <label for="fromDate">From Date</label>
        <InputDate id="fromDate" class="form-control" @bind-Value="FormBooking.FromDate" />
    </div>
    <div class="form-group">
        <label for="toDate">To Date</label>
        <InputDate id="toDate" class="form-control" @bind-Value="FormBooking.ToDate" />
    </div>
    <div class="form-group">
        <label for="userId">User Id</label>
        <InputNumber id="userId" class="form-control" @bind-Value="FormBooking.UserId" />
    </div>
    <div class="form-group">
        <label for="itemId">Item Id</label>
        <InputNumber id="itemId" class="form-control" @bind-Value="FormBooking.ItemId" />
    </div>
    <div class="form-group">
        <label for="price">Price</label>
        <InputNumber id="price" class="form-control" @bind-Value="FormBooking.Price" />
    </div>
    <div class="form-group">
        <label for="comment">Comment</label>
        <InputText id="comment" class="form-control" @bind-Value="FormBooking.Comment" />
    </div>

    <button type="submit" class="btn btn-success mt-2">Create</button>
</EditForm>
